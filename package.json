{
  "name": "formulize",
  "version": "0.1.0",
  "description": "Local-first, open-source name→LaTeX formula search. Type a concept, get correct LaTeX + a rendered image, instantly, offline, free. Math, physics, astrophysics, chemistry.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "latex",
    "formula",
    "math",
    "physics",
    "chemistry",
    "katex",
    "mathjax",
    "search",
    "semantic-search",
    "react"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./core": {
      "types": "./dist/lib/core/index.d.ts",
      "import": "./dist/lib/core/index.js"
    },
    "./styles.css": "./dist/lib/formulize.css"
  },
  "files": [
    "dist/lib",
    "dist/index.json",
    "README.md"
  ],
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "build:data": "tsx scripts/build-index.ts",
    "build:quantities": "tsx scripts/build-quantities.ts",
    "build:lib": "vite build",
    "build": "npm run build:data && npm run build:lib",
    "dev": "vite --config vite.demo.config.ts",
    "demo:build": "npm run build:data && vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "fflate": "^0.8.3",
    "fuse.js": "^7.0.0",
    "katex": "^0.16.11",
    "mathjax-full": "^3.2.2",
    "mathml2omml": "^0.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.1",
    "mathjs": "^12.4.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
